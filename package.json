{
  "name": "@alsaeedfayed/ui-lib",
  "version": "0.1.0",
  "description": "Shared UI component library for microfrontend apps",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": {
      "types": "./dist/styles.css.d.ts",
      "default": "./dist/styles.css"
    }
  },
  "files": [
    "dist",
    "styles.css.d.ts"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup && npm run build:css",
    "build:css": "npx tailwindcss -i ./styles/index.css -o ./dist/styles.css --minify && cp styles.css.d.ts dist/styles.css.d.ts",
    "dev": "vite",
    "dev:build": "tsup --watch",
    "lint": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alsaeedfayed/ui-lib.git"
  },
  "keywords": [
    "ui",
    "components",
    "react",
    "shadcn",
    "tailwindcss"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/alsaeedfayed/ui-lib/issues"
  },
  "homepage": "https://github.com/alsaeedfayed/ui-lib#readme",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^3.8.5",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
